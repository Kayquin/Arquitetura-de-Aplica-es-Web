    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registra um novo usuario e retorna o token JWT.",
        "description": "Exemplo:\r\n{\r\n  \"email\": \"usuario@email.com\",\r\n  \"password\": \"123456\",\r\n  \"role\": \"usuario\",\r\n  \"nome\": \"Ana Silva\",\r\n  \"cpf\": \"12345678901\",\r\n  \"telefone\": \"11999999999\"\r\n}",
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRegisterDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRegisterDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRegisterDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          }
        }
      }
    },
